# Python / ETL
etl/.venv/
etl/__pycache__/
etl/src/etl/__pycache__/
etl/*.egg-info/
**/__pycache__/
*.pyc
*.pyo

# Cache: geocode results stay local, but the source PDFs ARE committed —
# they're the irreplaceable input (17 MB for all 865) and colinday.co.uk
# is one retired gentleman's personal website.
data/.cache/*
!data/.cache/pdfs/

# Generated images (large binaries — rebuilt by ETL)
data/dist/images/
data/dist/overlays/

# docs/ is the static PWA build (generated by hereabouts-build-pwa, deployed to Surge).
# Images are large derived binaries — regenerated from the PDF cache, not committed.
# The houses.json inside docs/ is committed (pre-merged, no server needed).
docs/images/

# Control points are SOURCE OF TRUTH — do NOT ignore
# data/control_points/ is intentionally tracked

# Expo / Node
app/node_modules/
app/.expo/
app/dist/
app/.env*

# Personal notes (not committed — correspondence, drafts, scratch)
notes/

# macOS
.DS_Store
**/.DS_Store

# Wrangler local cache (contains Cloudflare account id/name; not needed in repo)
.wrangler/
etl/.wrangler/
